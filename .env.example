# ─────────────────────────────────────────────────────────────
# TechMYPE — Plantilla de variables de entorno
# Copia como .env y rellena los valores. Para producción
# configura directamente en Dokploy (nunca subas .env a git).
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL="postgresql://techmype:TU_PASSWORD@postgres:5432/techmype_db"
POSTGRES_PASSWORD="TU_PASSWORD_SEGURA"

# WhatsApp Business
NEXT_PUBLIC_WHATSAPP_NUMBER="51970435903"
NEXT_PUBLIC_WHATSAPP_DEFAULT_MSG="Hola, me interesa digitalizar mi negocio. ¿Me pueden orientar?"

# Panel de administración → /admin/login  (genera con: openssl rand -base64 32)
ADMIN_SECRET="GENERA_UN_SECRETO_SEGURO_AQUI"

# Analytics (opcional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# URL pública
NEXT_PUBLIC_APP_URL="https://techmype.pe"
